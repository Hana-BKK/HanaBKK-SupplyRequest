<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ระบบเบิกของ - Hana BKK</title>
    <!-- Tailwind CSS สำหรับความสวยงาม -->
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <!-- html2pdf.js สำหรับแปลงหน้าเว็บเป็น PDF -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <style>
        body { font-family: 'Prompt', sans-serif; }
    </style>
</head>
<body class="bg-gray-50 min-h-screen p-4 md:p-8">

    <div class="max-w-4xl mx-auto bg-white rounded-2xl shadow-xl overflow-hidden p-6 md:p-10" id="requisition-form">
        <!-- Header -->
        <div class="border-b pb-6 text-center md:text-left flex flex-col md:flex-row justify-between items-center gap-4">
            <div>
                <h1 class="text-3xl font-bold text-gray-800 tracking-wide">HANA BKK</h1>
                <p class="text-gray-500 mt-1">แบบฟอร์มใบเบิกวัสดุอุปกรณ์ภายในสำนักงาน</p>
            </div>
            <div class="text-right">
                <p class="text-sm text-gray-500">วันที่เบิก: <span id="current-date" class="font-medium text-gray-700"></span></p>
            </div>
        </div>

        <!-- ส่วนที่ 1: ข้อมูลผู้เบิก -->
        <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">ชื่อ-นามสกุล ผู้เบิก</label>
                <input type="text" id="emp-name" placeholder="กรอกชื่อของคุณ" class="w-full px-4 py-2.5 border rounded-lg focus:ring-2 focus:ring-emerald-500 focus:outline-none transition-all">
            </div>
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">แผนก (Department)</label>
                <select id="emp-dept" class="w-full px-4 py-2.5 border rounded-lg focus:ring-2 focus:ring-emerald-500 focus:outline-none transition-all">
                    <option value="Salon">Salon</option>
                    <option value="Front">Front</option>
                    <option value="Housekeeping">Housekeeping</option>
                </select>
            </div>
        </div>

        <!-- ส่วนที่ 2: ฟอร์มเพิ่มสินค้า (ตารางชั่วคราว) -->
        <div class="mt-10 bg-gray-50 p-4 rounded-xl border border-dashed border-gray-300 data-html2pdf-ignore">
            <h3 class="text-md font-bold text-gray-700 mb-3">➕ เพิ่มรายการสินค้าที่ต้องการเบิก</h3>
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4 items-end">
                <div class="md:col-span-1">
                    <label class="block text-xs font-semibold text-gray-600 mb-1">ประเภท</label>
                    <select id="item-category" class="w-full px-3 py-2 bg-white border rounded-lg text-sm">
                        <option value="อุปกรณ์ทำความสะอาด">อุปกรณ์ทำความสะอาด</option>
                        <option value="ร้านเสริมสวย">ร้านเสริมสวย</option>
                        <option value="อุปกรณ์สำนักงาน">อุปกรณ์สำนักงาน</option>
                        <option value="อื่นๆ">อื่นๆ</option>
                    </select>
                </div>
                <div class="md:col-span-2">
                    <label class="block text-xs font-semibold text-gray-600 mb-1">ชื่อสินค้า / รายละเอียด</label>
                    <input type="text" id="item-name" placeholder="เช่น กระดาษ A4, แชมพู" class="w-full px-3 py-2 bg-white border rounded-lg text-sm">
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-600 mb-1">จำนวน</label>
                    <div class="flex gap-2">
                        <input type="number" id="item-qty" min="1" value="1" class="w-20 px-3 py-2 bg-white border rounded-lg text-sm text-center">
                        <button type="button" onclick="addItem()" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-medium py-2 px-4 rounded-lg text-sm transition-colors cursor-pointer">
                            เพิ่มลงรายการ
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- ส่วนที่ 3: ตารางแสดงรายการที่สั่ง (จะถูกพิมพ์ออก PDF) -->
        <div class="mt-8">
            <h2 class="text-lg font-bold text-gray-800 mb-3">รายการที่ขอเบิก</h2>
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-gray-100 text-gray-700 text-sm font-semibold uppercase">
                            <th class="p-3 rounded-l-lg text-center w-12">ลำดับ</th>
                            <th class="p-3">ประเภท</th>
                            <th class="p-3"> รายการสินค้า</th>
                            <th class="p-3 text-center w-24">จำนวน</th>
                            <th class="p-3 rounded-r-lg text-center w-20 data-html2pdf-ignore">จัดการ</th>
                        </tr>
                    </thead>
                    <tbody id="items-table-body" class="text-sm divide-y divide-gray-100">
                        <!-- รายการสินค้าจะมาโผล่ตรงนี้ -->
                        <tr id="empty-row">
                            <td colspan="5" class="p-8 text-center text-gray-400 italic">ยังไม่มีการเพิ่มรายการสินค้า</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- ส่วนเซ็นชื่อท้ายเอกสาร (แสดงเฉพาะตอนเป็น PDF หรือตรวจทาน) -->
        <div class="mt-16 grid grid-cols-2 gap-12 text-center pt-8 border-t border-gray-100">
            <div>
                <p class="text-sm text-gray-600 mb-12">ลงชื่อ: .............................................................</p>
                <p class="text-sm font-semibold text-gray-700">( ผู้ขอเบิก )</p>
            </div>
            <div>
                <p class="text-sm text-gray-600 mb-12">ลงชื่อ: .............................................................</p>
                <p class="text-sm font-semibold text-gray-700">( ผู้อนุมัติ )</p>
            </div>
        </div>

        <!-- ปุ่มกดดาวน์โหลด PDF -->
        <div class="mt-10 flex justify-end gap-4 data-html2pdf-ignore">
            <button type="button" onclick="exportToPDF()" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-6 rounded-xl shadow-lg shadow-blue-100 flex items-center gap-2 transition-all cursor-pointer">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                ส่งออกเป็นไฟล์ PDF
            </button>
        </div>
    </div>

    <script>
        // แสดงวันที่ปัจจุบัน
        const options = { year: 'numeric', month: 'long', day: 'numeric' };
        document.getElementById('current-date').innerText = new Date().toLocaleDateString('th-TH', options);

        let itemsList = [];

        // ฟังก์ชันเพิ่มสินค้าเข้าไปในออเดอร์
        function addItem() {
            const category = document.getElementById('item-category').value;
            const name = document.getElementById('item-name').value.trim();
            const qty = parseInt(document.getElementById('item-qty').value);

            if (name === "") {
                alert("กรุณากรอกชื่อสินค้า");
                return;
            }
            if (qty <= 0 || isNaN(qty)) {
                alert("กรุณากรอกจำนวนที่ถูกต้อง");
                return;
            }

            // เพิ่มเข้า Array
            itemsList.push({ category, name, qty });
            
            // ล้างค่าในช่องกรอกชื่อสินค้าเพื่อให้พิมพ์รายการต่อไปได้เลย
            document.getElementById('item-name').value = "";
            document.getElementById('item-qty').value = "1";

            renderTable();
        }

        // ฟังก์ชันลบสินค้าออกจากรายการ
        function removeItem(index) {
            itemsList.splice(index, 1);
            renderTable();
        }

        // ฟังก์ชันวาดตารางใหม่เมื่อมีการเปลี่ยนแปลงข้อมูล
        function renderTable() {
            const tbody = document.getElementById('items-table-body');
            tbody.innerHTML = "";

            if (itemsList.length === 0) {
                tbody.innerHTML = `
                    <tr id="empty-row">
                        <td colspan="5" class="p-8 text-center text-gray-400 italic">ยังไม่มีการเพิ่มรายการสินค้า</td>
                    </tr>`;
                return;
            }

            itemsList.forEach((item, index) => {
                const tr = document.createElement('tr');
                tr.className = "hover:bg-gray-50 transition-colors";
                tr.innerHTML = `
                    <td class="p-3 text-center font-medium text-gray-600">${index + 1}</td>
                    <td class="p-3 text-gray-700">${item.category}</td>
                    <td class="p-3 text-gray-800 font-medium">${item.name}</td>
                    <td class="p-3 text-center text-gray-700 font-semibold">${item.qty}</td>
                    <td class="p-3 text-center data-html2pdf-ignore">
                        <button onclick="removeItem(${index})" class="text-red-500 hover:text-red-700 font-medium cursor-pointer">ลบ</button>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        // ฟังก์ชันแปลงหน้าเว็บเป็น PDF
        function exportToPDF() {
            const name = document.getElementById('emp-name').value.trim();
            if (!name) {
                alert("กรุณากรอกชื่อผู้เบิกก่อนส่งออก PDF");
                return;
            }
            if (itemsList.length === 0) {
                alert("กรุณาเพิ่มสินค้าอย่างน้อย 1 รายการก่อนส่งออก PDF");
                return;
            }

            const element = document.getElementById('requisition-form');
            
            // ตั้งค่าสำหรับดาวน์โหลด PDF
            const opt = {
                margin:       [0.5, 0.5, 0.5, 0.5],
                filename:     `ใบเบิกของ_HanaBKK_${name}.pdf`,
                image:        { type: 'jpeg', quality: 0.98 },
                html2canvas:  { scale: 2, useCORS: true },
                jsPDF:        { unit: 'in', format: 'a4', orientation: 'portrait' }
            };

            // ดำเนินการสร้าง PDF
            html2pdf().set(opt).from(element).save();
        }
    </script>
</body>
</html>
